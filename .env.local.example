# Copy to `.env.local` and fill in real values. Never commit `.env.local`.

NODE_ENV=development

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080

# Generate with: npm run generate:keys
JWT_SECRET=replace-with-64-char-hex-from-generate-keys
ENCRYPTION_KEY=replace-with-32-char-key-from-generate-keys
CSRF_SECRET=replace-with-64-char-hex-from-generate-keys

# Local Redis (run: npm run dev:services)
REDIS_URL=redis://localhost:6379

# Optional — rate limiting in production
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — storage / payments (dev can leave empty if unused)
ARVAN_CLOUD_ENDPOINT=
ARVAN_CLOUD_ACCESS_KEY=
ARVAN_CLOUD_SECRET_KEY=
ARVAN_CLOUD_BUCKET=
ZIBAL_MERCHANT_ID=
