{
    "name": "Vista - پلتفرم اجتماعی",
    "short_name": "Vista",
    "description": "پلتفرم اجتماعی Vista برای اشتراک‌گذاری محتوا",
    "start_url": "/feed",
    "display": "standalone",
    "background_color": "#F8F9FF",
    "theme_color": "#6366F1",
    "orientation": "portrait-primary",
    "scope": "/",
    "lang": "fa",
    "dir": "rtl",
    "icons": [
        {
            "src": "/icons/icon-192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any"
        },
        {
            "src": "/icons/icon-512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "any maskable"
        }
    ],
    "categories": ["social", "entertainment"],
    "shortcuts": [
        {
            "name": "فید",
            "short_name": "فید",
            "description": "مشاهده فید",
            "url": "/feed",
            "icons": [{ "src": "/icons/icon-192.png", "sizes": "96x96" }]
        },
        {
            "name": "پست جدید",
            "short_name": "پست",
            "description": "ایجاد پست جدید",
            "url": "/post",
            "icons": [{ "src": "/icons/icon-192.png", "sizes": "96x96" }]
        },
        {
            "name": "پیام‌ها",
            "short_name": "پیام",
            "description": "مشاهده پیام‌ها",
            "url": "/messages",
            "icons": [{ "src": "/icons/icon-192.png", "sizes": "96x96" }]
        },
        {
            "name": "اطراف من",
            "short_name": "نزدیک",
            "description": "افراد نزدیک به شما",
            "url": "/nearby",
            "icons": [{ "src": "/icons/icon-192.png", "sizes": "96x96" }]
        }
    ],
    "share_target": {
        "action": "/share-target",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "title": "title",
            "text": "text",
            "url": "url",
            "files": [
                {
                    "name": "media",
                    "accept": ["image/*", "video/*"]
                }
            ]
        }
    },
    "prefer_related_applications": false,
    "launch_handler": {
        "client_mode": "navigate-existing"
    },
    "handle_links": "preferred"
}
