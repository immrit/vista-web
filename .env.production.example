NODE_ENV=production

# Public URLs baked into the Next.js client bundle at build time.
NEXT_PUBLIC_API_URL=https://api.coffevista.ir
NEXT_PUBLIC_APP_URL=https://cafevista.ir
NEXT_PUBLIC_APP_VERSION=2.6.0

# Server-side secrets used by Next API routes.
JWT_SECRET=change-me-at-least-32-characters-long
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
CSRF_SECRET=change-me-at-least-32-characters-long
CRON_SECRET=change-me-for-cron-routes

# Optional integrations.
NEXT_PUBLIC_SENTRY_DSN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
ZIBAL_MERCHANT_ID=

# Docker host port.
VISTA_WEB_PORT=3000
